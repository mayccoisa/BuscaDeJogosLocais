<UserControl x:Class="BuscaDeJogosLocais.ScanResultWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:BuscaDeJogosLocais"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="900">
    <UserControl.Resources>
        <local:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <Style x:Key="GroupHeaderStyle" TargetType="{x:Type GroupItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GroupItem}">
                        <Expander IsExpanded="True" Background="#11FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="0,0,0,1" Margin="0,0,0,5">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📁 Origem: " FontWeight="Bold" Opacity="0.7" />
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="Gold" />
                                    <TextBlock Text="{Binding ItemCount, StringFormat=' ({0} itens)'}" Opacity="0.5" Margin="5,0,0,0" />
                                </StackPanel>
                            </Expander.Header>
                            <ItemsPresenter />
                        </Expander>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{Binding HeaderText}" FontSize="14" FontWeight="Bold" Foreground="White" />
            <TextBlock Text="Selecione os jogos que deseja importar. Use 🚫 para ignorar permanentemente."
                       FontStyle="Italic" Opacity="0.6" FontSize="11" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Filtro -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <CheckBox Content="Ocultar jogos já na biblioteca" IsChecked="{Binding OcultarJaExistentes}"
                      VerticalContentAlignment="Center" Margin="0,0,20,0" />
            <TextBlock Text="{Binding ContagemTexto}" VerticalAlignment="Center" Opacity="0.7" FontSize="11" />
        </StackPanel>

        <!-- DataGrid com resultados -->
        <DataGrid x:Name="GridResultados" Grid.Row="2"
                  ItemsSource="{Binding ResultadosView}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  Background="#22FFFFFF"
                  RowBackground="Transparent"
                  AlternatingRowBackground="#11FFFFFF"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#22FFFFFF"
                  HeadersVisibility="Column"
                  SelectionMode="Extended">
            <DataGrid.GroupStyle>
                <GroupStyle ContainerStyle="{StaticResource GroupHeaderStyle}" />
            </DataGrid.GroupStyle>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Importar" Width="65" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Selecionado, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      IsEnabled="{Binding JaExiste, Converter={StaticResource InverseBooleanConverter}}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Jogo" Binding="{Binding Nome}" Width="*" IsReadOnly="True" />

                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="130" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding JaExiste}" Value="True">
                                    <Setter Property="Foreground" Value="#888888" />
                                    <Setter Property="FontStyle" Value="Italic" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding JaExiste}" Value="False">
                                    <Setter Property="Foreground" Value="LightGreen" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Pasta" Binding="{Binding PastaMonitoradaPai}" Width="180" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Opacity" Value="0.6" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="Ignorar" Width="65" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="🚫" ToolTip="Não mostrar este jogo em buscas futuras"
                                    Tag="{Binding}"
                                    Click="OnIgnorarClick"
                                    Padding="4,2"
                                    HorizontalAlignment="Center"
                                    Cursor="Hand"
                                    Background="Transparent"
                                    BorderThickness="0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Botões -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="✅ IMPORTAR SELECIONADOS" Click="OnImportarClick"
                    Padding="15,7" Margin="0,0,10,0" Cursor="Hand" />
            <Button Content="Fechar" Click="OnFecharClick" Padding="15,7" Cursor="Hand" />
        </StackPanel>
    </Grid>
</UserControl>
